# Next on Wembley — environment template.
# Copy to .env.local for local dev, or set these in the Vercel project.
# Never commit real values — only this template is tracked.

# Postgres connection string (Vercel Postgres / Neon).
# Vercel injects this automatically when you attach a Postgres store.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# iron-session cookie encryption key — 32+ random chars.
# Generate one with:  openssl rand -base64 32
SESSION_SECRET=""

# Anthropic API key — recommendation generation.
ANTHROPIC_API_KEY=""

# TMDb API key (v3) — show metadata, posters, providers.
TMDB_API_KEY=""

# Optional — bcrypt cost factor for passcode hashing (default 12).
# BCRYPT_COST="12"

# Used only by `npm run db:seed` to set the two household passcodes.
SEED_COREY_PASSCODE=""
SEED_JAIMIE_PASSCODE=""
