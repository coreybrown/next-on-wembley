// Next on Wembley — schema through M3.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum WatchStatus {
  want_to_watch
  watching
  paused
  completed
  dropped
}

enum UserRating {
  like
  dislike
  meh
}

enum RecModel {
  haiku
  sonnet
}

enum RecScope {
  co_watch
  corey
  jaimie
}

enum RecRunStatus {
  ok
  failed
}

enum VoteValue {
  agree
  disagree
  maybe
}

model User {
  id                Int                  @id @default(autoincrement())
  username          String               @unique
  displayName       String
  passcodeHash      String
  // Per-user preferred Anthropic model for recommendation generation.
  // Changing this value triggers a refresh (wired up in M3 Phase 10).
  recModel          RecModel             @default(haiku)
  createdAt         DateTime             @default(now())
  subscriptions     UserSubscription[]
  watchEntries      WatchEntry[]
  triggeredRecRuns  RecommendationRun[]
  showVotes         ShowVote[]
}

model UserSubscription {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platformKey String
  createdAt   DateTime @default(now())

  @@unique([userId, platformKey])
}

model Show {
  id                     Int                        @id @default(autoincrement())
  tmdbId                 Int                        @unique
  title                  String
  // TMDb plot summary, displayed verbatim on the Show Detail page.
  // Persisted on every metadata refresh; null for shows seeded before
  // the column landed (resolved by their next sync).
  overview               String?
  posterUrl              String?
  genres                 String?
  totalSeasons           Int?
  totalEpisodes          Int?
  // JSON-encoded `[{ season_number, episode_count }, ...]` excluding season 0
  // specials. Used by M2's episodes-remaining math.
  seasonsJson            String?
  tmdbRating             Float?
  trailerUrl             String?
  productionStatus       String?
  lastSyncedAt           DateTime                   @default(now())
  watchEntries           WatchEntry[]
  providers              ShowProvider[]
  recItems               RecommendationItem[]
  votes                  ShowVote[]
  continuationDetections ContinuationDetectionLog[]
}

model ShowProvider {
  id               Int    @id @default(autoincrement())
  showId           Int
  show             Show   @relation(fields: [showId], references: [id], onDelete: Cascade)
  platformKey      String
  region           String @default("CA")
  monetizationType String @default("flatrate")

  @@unique([showId, platformKey, region, monetizationType])
}

model WatchEntry {
  id                      Int          @id @default(autoincrement())
  userId                  Int
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  showId                  Int
  show                    Show         @relation(fields: [showId], references: [id], onDelete: Cascade)
  status                  WatchStatus
  currentSeason           Int?
  // Whether the user has finished `currentSeason`. Captures the
  // mid-season vs. between-seasons distinction without doing
  // episode-by-episode tracking.
  currentSeasonCompleted  Boolean      @default(false)
  userRating              UserRating?
  notes                   String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  @@unique([userId, showId])
}

// A single LLM-driven recommendation generation run. One run produces one
// ranked list (co_watch, corey's picks, or jaimie's picks).
model RecommendationRun {
  id           Int                  @id @default(autoincrement())
  // The user who triggered this run — owns the model preference + accounting.
  triggeredBy  Int
  triggerUser  User                 @relation(fields: [triggeredBy], references: [id], onDelete: Cascade)
  scope        RecScope
  // The Anthropic model id used for generation (e.g. "claude-haiku-4-5").
  modelId      String
  // Optional free-text mood from the refresh form. Persisted so the UI can
  // restore it on retry (PRD §6 latency UX).
  mood         String?
  status       RecRunStatus
  errorMessage String?
  createdAt    DateTime             @default(now())
  items        RecommendationItem[]
}

model RecommendationItem {
  id               Int                  @id @default(autoincrement())
  runId            Int
  run              RecommendationRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  position         Int
  tmdbId           Int
  showId           Int?
  show             Show?                @relation(fields: [showId], references: [id], onDelete: SetNull)
  title            String
  year             String?
  posterUrl        String?
  shortExplanation String
  longExplanation  String
  isContinuation   Boolean              @default(false)
}

// Per-(user, show) vote. Keyed on Show so the signal survives across
// RecommendationRun refreshes — if Corey agreed with Severance once, the
// agree shows on every future rec for Severance and the prompt-side
// filter keeps Disagrees out of his next pass. Replaces the M3 Phase 9
// RecommendationVote table (keyed on the ephemeral RecommendationItem).
model ShowVote {
  id        Int       @id @default(autoincrement())
  showId    Int
  show      Show      @relation(fields: [showId], references: [id], onDelete: Cascade)
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  vote      VoteValue
  createdAt DateTime  @default(now())

  @@unique([showId, userId])
}

// One row per Anthropic call so we can sum monthly spend and enforce
// the PRD §10 cap (<$15/month with 75% warning, hard pause at 100%).
// costUsd is computed at log time from the model's per-MTok rates so
// the cap math is independent of future pricing changes.
model LlmCallLog {
  id            Int      @id @default(autoincrement())
  modelId       String
  inputTokens   Int
  outputTokens  Int
  costUsd       Float
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// Powers the §10 success metric: "continuations surfaced within one week of
// the new episode's air date." Written by the M2 refresh job when it sees
// new episodes past every WatchEntry's currentSeason for a show.
model ContinuationDetectionLog {
  id                    Int       @id @default(autoincrement())
  showId                Int
  show                  Show      @relation(fields: [showId], references: [id], onDelete: Cascade)
  detectedAt            DateTime  @default(now())
  tmdbNewEpisodeAirDate DateTime
  firstSurfacedAt       DateTime?
}
